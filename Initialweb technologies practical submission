        * {
            box-style: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
        }

        body {
            display: flex;
            background-color: #f4f6f9;
            color: #333;
            height: 100vh;
            overflow: hidden;
        }

        /* Sidebar Navigation */
        #sidebar {
            width: 320px;
            background-color: #2c3e50;
            color: #ecf0f1;
            padding: 20px;
            display: flex;
            flex-direction: column;
            box-shadow: 2px 0 5px rgba(0,0,0,0.1);
        }

        #sidebar h2 {
            font-size: 1.2rem;
            margin-bottom: 15px;
            border-bottom: 2px solid #34495e;
            padding-bottom: 10px;
            text-align: center;
        }

        .task-list {
            overflow-y: auto;
            flex-grow: 1;
            padding-right: 5px;
        }

        .task-btn {
            width: 100%;
            background-color: #34495e;
            color: #fff;
            border: none;
            padding: 10px;
            margin-bottom: 8px;
            text-align: left;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.9rem;
            transition: background 0.2s;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .task-btn:hover {
            background-color: #3498db;
        }

        .task-btn.active {
            background-color: #2ecc71;
            font-weight: bold;
        }

        /* Main Content Container */
        #main-content {
            flex-grow: 1;
            padding: 30px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* Profile Card Top Section */
        #profile-section {
            background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
            color: white;
            padding: 25px;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        #profile-section h1 {
            font-size: 1.8rem;
            margin-bottom: 10px;
        }

        .profile-details {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            font-size: 1rem;
        }

        /* Task View Frame */
        #task-display-container {
            background: #ffffff;
            border-radius: 8px;
            padding: 25px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            border-top: 5px solid #2ecc71;
            flex-grow: 1;
        }

        #task-description-header {
            background-color: #f8f9fa;
            border-left: 5px solid #3498db;
            padding: 15px;
            margin-bottom: 25px;
            border-radius: 0 4px 4px 0;
        }

        #task-description-header h3 {
            color: #2c3e50;
            margin-bottom: 5px;
        }

        /* UI elements for internal components */
        .workspace-ui {
            display: flex;
            flex-direction: column;
            gap: 15px;
            max-width: 500px;
            background: #fafafa;
            padding: 20px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
        }

        .workspace-ui input, .workspace-ui select, .workspace-ui button {
            padding: 10px;
            font-size: 1rem;
            border-radius: 4px;
            border: 1px solid #ccc;
        }

        .workspace-ui button {
            background-color: #3498db;
            color: white;
            border: none;
            cursor: pointer;
            font-weight: bold;
        }

        .workspace-ui button:hover {
            background-color: #2980b9;
        }

        .result-box {
            margin-top: 10px;
            padding: 12px;
            background-color: #e8f4fd;
            border-left: 4px solid #3498db;
            font-weight: 500;
            word-break: break-all;
        }

        /* Dynamic Card Layout Object Styles */
        .card-view {
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            max-width: 300px;
        }
        .card-view h4 { margin-bottom: 10px; color: #2c3e50; border-bottom: 1px solid #eee; padding-bottom: 5px;}
        .card-view p { margin: 5px 0; color: #555;}

        /* Digital Clock & Stopwatch View styling */
        .huge-timer {
            font-size: 2.5rem;
            font-family: monospace;
            color: #2c3e50;
            background: #eef2f3;
            padding: 15px;
            text-align: center;
            border-radius: 6px;
            letter-spacing: 2px;
        }
        .btn-group { display: flex; gap: 10px; }
        .btn-group button { flex: 1; }
    </style>
</head>
